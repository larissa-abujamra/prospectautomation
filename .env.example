# Copie para .env.local e preencha com os valores do seu projeto Supabase.
# (Settings → API no painel do Supabase). NUNCA commite o .env.local com chaves reais.
# A anon key é pública por design (protegida por RLS), mas mesmo assim não vai pro git.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
